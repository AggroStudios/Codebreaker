{
  "name": "codebreaker",
  "private": true,
  "version": "0.6.107",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=LOCAL_DEV vite --open",
    "dev:electron": "cross-env NODE_ENV=LOCAL_DEV ELECTRON=true vite",
    "build": "tsc && vite build",
    "build:electron": "tsc && cross-env ELECTRON=true vite build && electron-builder",
    "electron:preview": "cross-env ELECTRON=true vite build && electron .",
    "preview": "vite preview",
    "test": "vitest run --reporter verbose",
    "lint": "eslint ./src --ext .ts,.tsx,.js,.jsx",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.aggrostudios.codebreaker",
    "productName": "Code Breaker",
    "copyright": "Copyright © 2026 Aggro Studios",
    "icon": "public/favicon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Game",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "lodash": "^4.18.1",
    "minimist": "^1.2.8",
    "node": "^24.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "steamworks.js": "^0.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/lodash": "^4.17.24",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "config": "^4.4.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.2",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^4.1.4"
  }
}
